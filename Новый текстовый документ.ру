def post_answer(feedback_id, answer_text):
    """Отправляет ответ в Wildberries"""
    url = WB_ANSWER_URL.format(id=feedback_id)
    headers = {"Authorization": WB_API_TOKEN, "Content-Type": "application/json"}
    data = {"text": answer_text}
    resp = requests.put(url, headers=headers, json=data, timeout=20)
    return resp.status_code == 204

def auto_reply_positive(review):
    """Автоответ на хороший отзыв (4-5★)"""
    import random
    reply = random.choice(POSITIVE_TEMPLATES)
    if post_answer(review["id"], reply):
        send_telegram(f"✅ Автоответ на ★★★★★\n{review['text'][:80]}...\nОтвет: {reply}")
    else:
        send_telegram(f"❌ Ошибка отправки автоответа\n{review['text'][:80]}")

def manual_negative_approve(review):
    """Отправляет админу отзыв с кнопками для выбора ответа"""
    ai_answer = ask_ai_for_reply(review["text"], review.get("productName", "аксессуар"))
    keyboard = {
        "inline_keyboard": [
            [{"text": "✅ Отправить этот ответ", "callback_data": f"send_{review['id']}_{ai_answer[:50]}"}],
            [{"text": "✏️ Написать самому", "callback_data": f"edit_{review['id']}"}]
        ]
    }
    text = f"❗️ <b>Новый негативный отзыв</b>\nТовар: {review.get('productName', '-')}\nТекст: {review['text']}\n\n<b>Предложенный ответ ИИ:</b>\n{ai_answer}"
    send_telegram(text, keyboard)

def main_loop():
    """Главный цикл"""
    send_telegram("🚀 Бот запущен. Отслеживаю отзывы...")
    while True:
        feedbacks = get_new_feedbacks()
        for fb in feedbacks:
            if fb["productValuation"] >= 4: # 4-5 ★
                auto_reply_positive(fb)
            else: # 1-3 ★
                manual_negative_approve(fb)
        time.sleep(900) # пауза 15 минут

if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO)
    main_loop()