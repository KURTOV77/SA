def send_telegram(text, keyboard=None):
    """Отправляет сообщение с кнопками в Telegram"""
    url = f"https://api.telegram.org/bot{TG_BOT_TOKEN}/sendMessage"
    data = {"chat_id": TG_YOUR_ID, "text": text, "parse_mode": "HTML"}
    if keyboard:
        data["reply_markup"] = json.dumps(keyboard)
    requests.post(url, data=data)

def get_new_feedbacks():
    """Забирает отзывы без ответа"""
    headers = {"Authorization": WB_API_TOKEN}
    params = {"isAnswered": False, "take": 20}
    try:
        resp = requests.get(WB_API_URL, headers=headers, params=params, timeout=30)
        if resp.status_code == 200:
            return resp.json().get("feedbacks", [])
        else:
            send_telegram(f"⚠️ Ошибка WB API: {resp.status_code}")
            return []
    except Exception as e:
        send_telegram(f"❌ Не удалось получить отзывы: {e}")
        return []

